# ─── WanderAI Configuration ─────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# ── App URL (used for payment callbacks) ──────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://thewanderlust.app

# ── WhatsApp (landing page CTA button) ────────────────────────────────────────
NEXT_PUBLIC_WA_PHONE=96512345678
NEXT_PUBLIC_WA_PREFILL=Hi! I'd like to plan a trip with WanderAI 🌍
NEXT_PUBLIC_MESSAGING_PROVIDER=wa_me

# ── Supabase (database) ───────────────────────────────────────────────────────
# Project URL — found in Supabase dashboard → Project Settings → API
SUPABASE_URL=https://tbsqnuqziflzgrcagmrq.supabase.co

# Service Role Key — found in Supabase dashboard → Project Settings → API → service_role
# ⚠️  NEVER expose this key on the client side (no NEXT_PUBLIC_ prefix)
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key-here...

# ── OpenRouter (AI agent replies) ─────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Model — any model on openrouter.ai works.
# Fast & cheap: anthropic/claude-haiku-4-5 | openai/gpt-4o-mini
# Best quality: anthropic/claude-sonnet-4-6 | openai/gpt-4o
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
NEXT_PUBLIC_OR_MODEL=claude-haiku-4-5

# ── MyFatoorah (payment gateway) ─────────────────────────────────────────────
# Test API key — get from https://apitest.myfatoorah.com → Settings → API
# Leave empty or as "TODO_..." to run in placeholder mode (no real charges)
MYFATOORAH_API_KEY=TODO_SET_MYFATOORAH_TEST_API_KEY

# Set to "true" for test environment, "false" for live production
MYFATOORAH_TEST=true
