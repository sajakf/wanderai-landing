# ─── WanderAI Configuration ────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# ── WhatsApp (landing page CTA button) ────────────────────────────────────────
# Your WhatsApp Business number in international format (digits only, no + or spaces)
NEXT_PUBLIC_WA_PHONE=14155552671

# Pre-filled message when a visitor taps the WhatsApp button
NEXT_PUBLIC_WA_PREFILL=Hi! I'd like to plan a trip with WanderAI 🌍

# Provider for the landing page CTA link (wa_me is free and needs no setup)
NEXT_PUBLIC_MESSAGING_PROVIDER=wa_me

# ── OpenRouter (AI agent replies) ─────────────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Model to use for replies — any model on openrouter.ai works.
# Cheap & fast options:  anthropic/claude-haiku-4-5 | openai/gpt-4o-mini | google/gemma-2-9b-it:free
# Best quality options:  anthropic/claude-sonnet-4-6 | openai/gpt-4o
OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# Shown in admin dashboard stats
NEXT_PUBLIC_OR_MODEL=claude-haiku-4-5

# ── Admin panel ───────────────────────────────────────────────────────────────
# Optional: set a password to protect /admin (implement middleware to use this)
# ADMIN_PASSWORD=changeme
